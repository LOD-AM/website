<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title or metadata.title }}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">

		<!-- Favicon -->
		<link rel="icon" type="image/x-icon" href="/img/favicon.ico">
		<link rel="icon" type="image/png" href="/img/logo.svg">

		<!-- LOD-AM Theme Variables - MUST load BEFORE Bootstrap -->
		<link rel="stylesheet" href="/css/bootstrap-theme.css">
		
		<!-- Bootstrap CSS -->
		<link rel="stylesheet" href="/css/bootstrap.min.css">
		
		<!-- Override Bootstrap's default variables that get set in :root -->
		<style>
			:root {
				/* Body */
				--bs-body-bg: var(--lodam-deep-umber);
				--bs-body-color: var(--lodam-chalk-white);
				
				/* Buttons - override Bootstrap defaults */
				--bs-btn-bg: transparent;
				--bs-btn-border-width: 1px;
				--bs-btn-color: var(--lodam-chalk-white);
				--bs-btn-box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.1);
				
				/* Primary Button */
				--bs-primary: var(--lodam-terracotta);
				--bs-primary-rgb: 203, 109, 81;
				--bs-primary-btn-bg: var(--lodam-burnt-sienna);
				--bs-primary-btn-border-color: var(--lodam-burnt-sienna);
				--bs-primary-btn-color: var(--lodam-chalk-white);
				--bs-primary-btn-hover-bg: #b84a2f;
				--bs-primary-btn-hover-border-color: #c15845;
				
				/* Secondary Button */
				--bs-secondary: var(--lodam-malachite);
				--bs-secondary-rgb: 61, 153, 112;
				--bs-secondary-btn-bg: var(--lodam-malachite);
				--bs-secondary-btn-border-color: var(--lodam-malachite);
				--bs-secondary-btn-color: var(--lodam-chalk-white);
				--bs-secondary-btn-hover-bg: #32825d;
				--bs-secondary-btn-hover-border-color: #2e7855;
				
				/* Success Button */
				--bs-success: var(--lodam-sage);
				--bs-success-rgb: 138, 155, 104;
				--bs-success-btn-bg: var(--lodam-sage);
				--bs-success-btn-border-color: var(--lodam-sage);
				--bs-success-btn-color: var(--lodam-deep-umber);
				--bs-success-btn-hover-bg: #758658;
				--bs-success-btn-hover-border-color: #6d7e52;
				
				/* Info Button */
				--bs-info: var(--lodam-ochre);
				--bs-info-rgb: 204, 139, 50;
				--bs-info-btn-bg: var(--lodam-ochre);
				--bs-info-btn-border-color: var(--lodam-ochre);
				--bs-info-btn-color: var(--lodam-deep-umber);
				--bs-info-btn-hover-bg: #b37a2b;
				--bs-info-btn-hover-border-color: #a97228;
				
				/* Warning Button */
				--bs-warning: var(--lodam-sunset-orange);
				--bs-warning-rgb: 242, 140, 40;
				--bs-warning-btn-bg: var(--lodam-sunset-orange);
				--bs-warning-btn-border-color: var(--lodam-sunset-orange);
				--bs-warning-btn-color: var(--lodam-deep-umber);
				--bs-warning-btn-hover-bg: #e07d24;
				--bs-warning-btn-hover-border-color: #d47321;
				
				/* Danger Button */
				--bs-danger: var(--lodam-burnt-sienna);
				--bs-danger-rgb: 212, 93, 61;
				--bs-danger-btn-bg: var(--lodam-burnt-sienna);
				--bs-danger-btn-border-color: var(--lodam-burnt-sienna);
				--bs-danger-btn-color: var(--lodam-chalk-white);
				--bs-danger-btn-hover-bg: #b84f34;
				--bs-danger-btn-hover-border-color: #a84830;
				
				/* Light & Dark Buttons */
				--bs-light: var(--lodam-deep-umber);
				--bs-light-rgb: 58, 46, 34;
				--bs-dark: var(--lodam-charcoal);
				--bs-dark-rgb: 42, 36, 29;
			}
		</style>
		
		<!-- Custom CSS -->
		<style>{% include "css/index.css" %}</style>
		<style>{% getBundle "css" %}</style>
		
		<!-- Bootstrap Icons -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
	</head>
	<body class="d-flex flex-column min-vh-100">
		<a href="#main" id="skip-link" class="visually-hidden">Skip to main content</a>

		<!-- Bootstrap Navbar -->
		<nav class="navbar navbar-expand-lg navbar-light bg-primary">
			<div class="container">
				<a class="navbar-brand" href="/">
					<img src="/img/logo.svg" alt="{{ metadata.title }}" style="height: 75px; width: 75px;" class="d-inline-block align-top">
				</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="mainNav">
					<ul class="navbar-nav me-auto">
					{%- for entry in collections.all | eleventyNavigation %}
						<li class="nav-item">
							<a class="nav-link" href="{{ entry.url }}"{% if entry.url == page.url %} aria-current="page"{% endif %}>{{ entry.title }}</a>
						</li>
					{%- endfor %}
					</ul>
				</div>
			</div>
		</nav>

		<main id="main" class="flex-grow-1">
			<div class="container py-4">
				<heading-anchors>
					{{ content | safe }}
				</heading-anchors>
			</div>
		</main>

		<!-- Bootstrap Footer -->
		<footer class="bg-charcoal text-white py-4 mt-auto">
			<div class="container">
				<div class="row">
					<div class="col-md-6">
						<p class="mb-0"><em>Built with <a href="https://www.11ty.dev/" class="text-white">{{ eleventy.generator }}</a></em></p>
					</div>
					<div class="col-md-6 text-md-end">
						<p class="mb-0">&copy; {{ metadata.author.name }} {{ "now" | date("yyyy") }}</p>
					</div>
				</div>
				<div class="row mt-3">
					<div class="col-12 text-center">
						<p class="mb-0 small">
							<a href="/impressum/" class="text-white me-3">Impressum</a>
							<a href="/privacy/" class="text-white me-3">Privacy Policy</a>
							<a href="https://github.com/LOD-AM/website" class="text-white me-3">GitHub</a>
						</p>
					</div>
				</div>
				<div class="row mt-2">
					<div class="col-12 text-center">
						<p class="mb-0 small">
							<a href="https://github.com/LOD-AM/website">LOD-AM Website</a> &copy; 2026 by <a href="https://lod-am.net">Fabian Fricke</a> is licensed under 
							<a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>
							<img src="https://mirrors.creativecommons.org/presskit/icons/cc.svg" alt="" style="max-width: 1em;max-height:1em;margin-left: .2em;vertical-align: baseline;">
							<img src="https://mirrors.creativecommons.org/presskit/icons/by.svg" alt="" style="max-width: 1em;max-height:1em;margin-left: .2em;vertical-align: baseline;">
						</p>
					</div>
				</div>
			</div>
		</footer>

		<!-- Bootstrap JS Bundle with Popper -->
		<script src="/js/bootstrap.bundle.min.js"></script>
		<script type="module" src="{% getBundleFileUrl "js" %}"></script>
	</body>
</html>
