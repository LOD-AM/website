---
eleventyNavigation:
  key: "Blogs"
  order: 2
---
<div class="container">
	<div class="row">
		<div class="col-lg-8">
			<h1 class="display-4 mb-4">Blogs</h1>
			<p class="lead mb-4">All {{ collections.blog | length }} blog posts</p>
			
			{% set postslist = collections.blog %}
			{% include "bloglist.njk" %}
		</div>
		
		<div class="col-lg-4">
			<div class="card mb-4">
				<div class="card-header">
					<h4 class="mb-0">Categories</h4>
				</div>
				<div class="card-body">
					{% for tag in collections | getKeys | filterTagList | sortAlphabetically %}
					<a href="/tags/{{ tag | slugify }}/" class="btn btn-sm m-1" style="{{ tag | getTagStyle }}">
						#{{ tag }} <span class="badge ms-1" style="{{ tag | getTagStyle }}">{{ collections[tag] | length }}</span>
					</a>
					{% endfor %}
				</div>
			</div>
		</div>
	</div>
</div>