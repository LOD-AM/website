<div class="container">
	<div class="row justify-content-center">
		<div class="col-lg-8">
			<h1 class="display-4 mb-4">Tags</h1>
			<p class="lead mb-4">Browse by category</p>
			
			<div class="d-flex flex-wrap gap-2">
			{% for tag in collections | getKeys | filterTagList | sortAlphabetically %}
				{% set tagUrl %}/tags/{{ tag | slugify }}/{% endset %}
				<a href="{{ tagUrl }}" class="btn" style="{{ tag | getTagStyle }}">
					{{ tag }} <span class="badge ms-1" style="{{ tag | getTagStyle }}">{{ collections[tag] | length }}</span>
				</a>
			{% endfor %}
			</div>
		</div>
	</div>
</div>