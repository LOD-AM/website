{
  "name": "The LOD-AM Website",
  "version": "0.01",
  "description": "The central website for the project Linked Open Data for Ancient Metallurgy (LOD-AM). Content licensed under CC-BY-4.0, code under MIT.",
  "type": "module",
  "scripts": {
    "build": "npx @11ty/eleventy",
    "build-nocolor": "cross-env NODE_DISABLE_COLORS=1 npx @11ty/eleventy",
    "build-ghpages": "npx @11ty/eleventy --pathprefix=/eleventy-base-blog/",
    "start": "npx @11ty/eleventy --serve --quiet",
    "start-ghpages": "npx @11ty/eleventy --pathprefix=/eleventy-base-blog/ --serve --quiet",
    "debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
    "debugstart": "cross-env DEBUG=Eleventy* npx @11ty/eleventy --serve --quiet",
    "benchmark": "cross-env DEBUG=Eleventy:Benchmark* npx @11ty/eleventy"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/LOD-AM/Website"
  },
  "author": {
    "name": "Fabian Fricke",
    "email": "info@lod-am.net"
  },
  "license": "MIT AND CC-BY-4.0",
  "engines": {
    "node": ">=18"
  },
  "funding": {
    "type": "individual",
    "name": "Fabian's income"
  },
  "bugs": {
    "url": "https://github.com/LOD-AM/Website/issues"
  },
  "homepage": "https://github.com/LOD-AM/Website",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "cross-env": "^10.1.0",
    "luxon": "^3.7.2",
    "prismjs": "^1.30.0",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@zachleat/heading-anchors": "^1.0.5",
    "bootstrap": "^5.3.8",
    "node-fetch": "^3.3.2"
  }
}